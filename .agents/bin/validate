#!/usr/bin/env bash
# Pre-push gate.
set -euo pipefail
cd "$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)"

base_branch="$(ruby -ryaml -e 'puts YAML.safe_load(File.read(".agents/agent-workflow.yml", encoding: "UTF-8"), aliases: false).fetch("base_branch")')"
if ! git check-ref-format --branch "${base_branch}" >/dev/null; then
  printf 'invalid base_branch in .agents/agent-workflow.yml: %s\n' "${base_branch}" >&2
  exit 1
fi

base_ref=""
# Prefer a current remote base even when a stale remote-tracking ref already
# exists. Offline and intentionally unreachable remotes remain valid local
# workflows, so a failed refresh is only fatal when neither base ref resolves.
if git remote get-url origin >/dev/null 2>&1; then
  git fetch --no-tags origin "+refs/heads/${base_branch}:refs/remotes/origin/${base_branch}" >/dev/null 2>&1 || true
fi
for candidate in "origin/${base_branch}" "${base_branch}"; do
  if git rev-parse --verify --quiet "${candidate}^{commit}" >/dev/null; then
    base_ref="${candidate}"
    break
  fi
done
[[ -n "${base_ref}" ]] || {
  printf 'unable to resolve base ref: origin/%s or local %s\n' "${base_branch}" "${base_branch}" >&2
  exit 1
}

git diff --check
git diff --cached --check
# A shallow checkout can have both refs but omit their common ancestor. Refresh
# both sides from a reachable origin before deciding whether the PR-range check
# is possible. A direct base-to-HEAD comparison would include unrelated history
# when the branches do not share an ancestor, so never use it as a substitute.
if [[ "$(git rev-parse --is-shallow-repository)" == "true" ]] && git remote get-url origin >/dev/null 2>&1; then
  head_branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  fetch_refs=("+refs/heads/${base_branch}:refs/remotes/origin/${base_branch}")
  if [[ -n "${head_branch}" ]] && git check-ref-format --branch "${head_branch}" >/dev/null; then
    fetch_refs+=("+refs/heads/${head_branch}:refs/remotes/origin/${head_branch}")
  fi
  git fetch --no-tags --unshallow origin "${fetch_refs[@]}" >/dev/null 2>&1 || true
fi

merge_base="$(git merge-base "${base_ref}" HEAD 2>/dev/null || true)"
if [[ -n "${merge_base}" ]]; then
  git diff --check "${merge_base}..HEAD"
else
  printf 'warning: no merge base for %s and HEAD; skipping base-range whitespace check\n' "${base_ref}" >&2
fi
ruby -e '
  require "open3"
  require "yaml"

  def read_utf8(label, contents)
    text = contents.force_encoding("UTF-8")
    abort "invalid UTF-8 in #{label}" unless text.valid_encoding?
    text
  end

  policy = read_utf8(".agents/agent-workflow.yml", File.binread(".agents/agent-workflow.yml"))
  YAML.safe_load(policy, aliases: false)

  tracked_docs = `git ls-files -z -- "*.md"`.split("\0")
  tracked_docs.each do |path|
    read_utf8(path, File.binread(path)) if File.file?(path)
    indexed, status = Open3.capture2("git", "show", ":#{path}")
    abort "unable to read staged document: #{path}" unless status.success?
    read_utf8("staged #{path}", indexed)
  end
'
